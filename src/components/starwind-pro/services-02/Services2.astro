---
import IconArrowRight from "@tabler/icons/outline/arrow-right.svg";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";

/** Service item configuration */
export interface Service {
  /** Service title */
  title: string;
  /** Service description */
  description: string;
  /** Optional link to service page */
  href?: string;
}

interface Props extends HTMLAttributes<"section"> {
  /** Badge/eyebrow text */
  badge?: string;
  /** Section heading */
  heading?: string;
  /** Section description */
  description?: string;
  /** Array of services to display */
  services?: Service[];
}

const sectionStyles = tv({
  base: "@container mx-auto w-full max-w-7xl px-4 py-24",
});

const {
  badge = "Services",
  heading = "How We Can Help",
  description = "We provide a range of professional services to meet your needs.",
  services = [],
  class: className,
  ...rest
} = Astro.props;
---

<section class={sectionStyles({ class: className })} {...rest}>
  <div class="max-w-2xl @xl:mx-auto @xl:text-center">
    <Badge variant="primary">{badge}</Badge>
    <h2 class="font-heading mt-4 text-3xl font-semibold tracking-tight @xl:text-4xl @3xl:text-5xl">
      {heading}
    </h2>
    <p class="text-muted-foreground mt-4 text-pretty @xl:text-lg">
      {description}
    </p>
  </div>

  <div class="mx-auto mt-16 max-w-3xl">
    <ul class="divide-border divide-y">
      {
        services.map((service, index) => (
          <li class="group py-6 first:pt-0 last:pb-0">
            <div class="flex flex-col gap-4 @xl:flex-row @xl:items-center @xl:justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <span class="text-muted-foreground font-mono text-sm">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <h3 class="font-heading text-lg font-semibold">{service.title}</h3>
                </div>
                <p class="text-muted-foreground mt-2 text-pretty @xl:ml-9">{service.description}</p>
              </div>
              {service.href && (
                <Button
                  variant="ghost"
                  href={service.href}
                  class="group/btn w-fit shrink-0 self-start @xl:self-center"
                >
                  View Details
                  <IconArrowRight class="size-4 transition-transform group-hover/btn:translate-x-1" />
                </Button>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
